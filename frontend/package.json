    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^15.11.7",
    "jsdom": "^29.1.1",
    "typescript": "latest",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
